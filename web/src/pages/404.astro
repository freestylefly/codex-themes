---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout locale="zh" title="页面未找到" description="这个页面没有找到，返回 Codex Themes 继续浏览主题。">
  <section class="not-found section-shell">
    <div class="eyebrow">404 / PAGE NOT FOUND</div>
    <h1>这个窗口暂时不存在。</h1>
    <p>返回主题画廊，选择一个真实存在的工作空间。</p>
    <a class="button button-dark" href="/themes">浏览主题</a>
  </section>
</BaseLayout>
