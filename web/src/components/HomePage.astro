---
import { Image } from "astro:assets";
import { ArrowLeft, ArrowRight, Palette, ShieldCheck, Sparkles, Wand2 } from "lucide-astro";
import aiStudioClient from "../assets/product/ai-studio-client.jpg";
import customThemeClient from "../assets/product/custom-theme-client.jpg";
import themeGalleryClient from "../assets/product/theme-gallery-client.jpg";
import BaseLayout from "../layouts/BaseLayout.astro";
import ThemeCard from "./ThemeCard.astro";
import { DOWNLOAD_URL } from "../config";
import { copy, href, localizeTheme, type Locale } from "../lib/i18n";
import { themes } from "../lib/themes";

const { locale } = Astro.props as { locale: Locale };
const t = copy[locale];
const heroThemeIds = [
  "moonlit-immortal",
  "mirror-lake-ribbon",
  "starcap-teemo",
  "shanhai-nexus",
  "neon-star-hunter",
  "mecha-cat-studio",
  "potion-workshop",
  "focus-capybara",
];
const heroThemes = heroThemeIds.map((id) => {
  const theme = themes.find((item) => item.id === id);
  if (!theme) throw new Error(`Missing home hero theme: ${id}`);
  return localizeTheme(theme, locale);
});
const featured = themes.slice(0, 12);
const description =
  locale === "zh"
    ? "从官方主题到本地 AI 生成，一键应用，也能随时恢复。"
    : "From official themes to local AI generation, apply a new workspace in one click and restore it whenever you like.";
---

<BaseLayout locale={locale} description={description} bodyClass="home-dark" themeColor="#080907">
  <section class="home-hero" data-home-carousel>
    <div class="home-theme-backdrop" aria-hidden="true">
      {heroThemes.map((theme, index) => (
        <Image
          class="home-theme-backdrop-image"
          data-backdrop-index={index}
          data-active={index === 0 ? "true" : "false"}
          data-backdrop-kind={theme.hasBackdropArtwork ? "artwork" : "preview"}
          src={theme.backdrop}
          alt=""
          widths={[960, 1440, 1920]}
          sizes="100vw"
          format="webp"
          loading={index === 0 ? "eager" : "lazy"}
          style={`object-position: ${theme.backdropFocus.x * 100}% ${theme.backdropFocus.y * 100}%`}
        />
      ))}
    </div>

    <div class="home-hero-main">
      <div class="home-hero-copy">
        <h1>
          {locale === "zh" ? (
            <>把 <em>Codex</em>，<br />换成你想进入的<br />工作空间。</>
          ) : (
            <>Turn <em>Codex</em> into<br />the workspace<br />you want to enter.</>
          )}
        </h1>
        <p>{description}</p>
        <div class="home-hero-actions">
          <a class="button home-primary-action" href={href(locale, "/themes")}>
            {locale === "zh" ? "浏览主题" : "Browse themes"}
            <ArrowRight size={17} stroke-width={1.8} aria-hidden="true" />
          </a>
          <div class="home-safety-note">
            <ShieldCheck size={18} stroke-width={1.7} aria-hidden="true" />
            {locale === "zh" ? "本地运行 · 不修改 Codex 安装包" : "Runs locally · Never modifies the Codex app"}
          </div>
        </div>
      </div>

      <div class="home-theme-showcase">
        <div class="home-theme-stage" aria-label={locale === "zh" ? "主题预览卡组" : "Theme preview deck"}>
          {heroThemes.map((theme, index) => (
            <button
              class="home-deck-card"
              type="button"
              data-carousel-card
              data-theme-index={index}
              data-depth={index < 3 ? index : "hidden"}
              aria-hidden={index < 3 ? "false" : "true"}
              aria-pressed={index === 0 ? "true" : "false"}
              tabindex={index < 3 ? 0 : -1}
              aria-label={`${locale === "zh" ? "预览" : "Preview"} ${theme.name}`}
            >
              <Image
                src={theme.preview}
                alt={`${theme.name} Codex theme preview`}
                widths={[620, 880, 1180]}
                sizes="(max-width: 820px) 74vw, 40vw"
                format="webp"
                loading={index === 0 ? "eager" : "lazy"}
              />
            </button>
          ))}
          <button class="home-rail-arrow home-rail-arrow-prev" type="button" data-carousel-prev aria-label={locale === "zh" ? "上一个主题" : "Previous theme"}>
            <ArrowLeft size={22} stroke-width={1.7} aria-hidden="true" />
          </button>
          <button class="home-rail-arrow home-rail-arrow-next" type="button" data-carousel-next aria-label={locale === "zh" ? "下一个主题" : "Next theme"}>
            <ArrowRight size={22} stroke-width={1.7} aria-hidden="true" />
          </button>
        </div>

        <div class="home-theme-rail">
          <div class="home-rail-thumbnails" role="radiogroup" aria-label={locale === "zh" ? "选择主图主题" : "Choose featured theme"}>
            {heroThemes.map((theme, index) => (
              <button
                class="home-rail-thumbnail"
                type="button"
                data-carousel-thumb
                data-theme-index={index}
                data-theme-name={theme.name.replace(/\s+[A-Z][\s\S]*$/, "")}
                role="radio"
                aria-checked={index === 0 ? "true" : "false"}
                aria-label={theme.name}
              >
                <Image
                  src={theme.preview}
                  alt=""
                  widths={[220, 360]}
                  sizes="(max-width: 820px) 24vw, 8vw"
                  format="webp"
                  loading={index === 0 ? "eager" : "lazy"}
                />
              </button>
            ))}
          </div>
          <div class="home-rail-meta" aria-live="polite">
            <strong data-carousel-name>{heroThemes[0].name.replace(/\s+[A-Z][\s\S]*$/, "")}</strong>
            <span data-carousel-count>01 / {String(heroThemes.length).padStart(2, "0")}</span>
            <div class="home-rail-progress" aria-hidden="true"><i data-carousel-progress></i></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="manifesto section-shell">
    <div class="section-kicker">01 / {locale === "zh" ? "为什么是 Codex Themes" : "Why Codex Themes"}</div>
    <div class="manifesto-grid">
      <h2>
        {locale === "zh"
          ? "你的工作空间，也应该拥有自己的性格。"
          : "Your workspace should have a personality of its own."}
      </h2>
      <p>
        {locale === "zh"
          ? "Codex Themes 不修改应用安装包。它在本机运行，把主题布局、颜色和装饰安全地应用到 Codex，并保留一键恢复官方外观的能力。"
          : "Codex Themes runs locally and never patches the installed app. It applies layout, color, and decoration safely, with a one-click return to the official look."}
      </p>
    </div>
    <div class="feature-grid">
      <article>
        <span>01</span>
        <h3>{locale === "zh" ? "一键应用" : "One-click apply"}</h3>
        <p>{locale === "zh" ? "选择主题、确认应用，刷新后的 Codex 自动保持主题。" : "Choose, confirm, and keep the look across Codex refreshes."}</p>
      </article>
      <article>
        <span>02</span>
        <h3>{locale === "zh" ? "本地且可恢复" : "Local and reversible"}</h3>
        <p>{locale === "zh" ? "不修改 app.asar，不接触 API Key，随时恢复官方外观。" : "No app.asar patches, no API keys, and a clean reset whenever you want."}</p>
      </article>
      <article>
        <span>03</span>
        <h3>{locale === "zh" ? "Codex CLI 生成" : "Made with Codex CLI"}</h3>
        <p>{locale === "zh" ? "从一句描述或参考图片出发，在本地生成主题图和主题配方。" : "Start with a brief or reference image and generate artwork plus a theme recipe locally."}</p>
      </article>
    </div>
  </section>

  <section class="creation-section section-shell" id="create-theme">
    <div class="creation-heading">
      <div>
        <div class="section-kicker">02 / {locale === "zh" ? "三种主题方式" : "Three ways to theme"}</div>
        <h2>{locale === "zh" ? "选择现成的，也可以从零创造。" : "Choose one ready-made, or create from scratch."}</h2>
      </div>
      <p>
        {locale === "zh"
          ? "从一键换肤，到可视化编辑，再到让本地 Codex 根据一句话和参考图生成完整主题，都在同一个桌面应用里完成。"
          : "Apply a finished look, build one visually, or let your local Codex turn a brief and reference image into a complete theme—all in one desktop app."}
      </p>
    </div>

    <div class="creation-path-grid">
      <article class="creation-path-card">
        <div class="creation-path-visual">
          <Image
            src={themeGalleryClient}
            alt={locale === "zh" ? "Codex Themes 客户端主题画廊" : "Codex Themes desktop theme gallery"}
            widths={[480, 720, 960]}
            sizes="(max-width: 820px) 100vw, 33vw"
            format="webp"
            loading="lazy"
          />
          <div class="creation-visual-badge">{locale === "zh" ? "10 款官方精选" : "10 curated themes"}</div>
          <div class="creation-ready-state"><i></i>{locale === "zh" ? "可直接应用" : "Ready to apply"}</div>
        </div>
        <div class="creation-path-copy">
          <div class="creation-path-meta"><span>01</span><Palette size={18} stroke-width={1.6} aria-hidden="true" /></div>
          <h3>{locale === "zh" ? "一键换主题" : "Apply in one click"}</h3>
          <p>{locale === "zh" ? "浏览官方主题，网页一键唤起应用，确认后立即切换，并且随时可以恢复。" : "Browse official themes, open the desktop app from the web, confirm, and switch instantly—with restore always available."}</p>
          <a class="creation-path-action" href={href(locale, "/themes")}>
            {locale === "zh" ? "浏览官方主题" : "Browse official themes"}<ArrowRight size={16} aria-hidden="true" />
          </a>
        </div>
      </article>

      <article class="creation-path-card">
        <div class="creation-path-visual">
          <Image
            src={customThemeClient}
            alt={locale === "zh" ? "Codex Themes 客户端自定义主题编辑器" : "Codex Themes desktop custom theme editor"}
            widths={[480, 720, 960]}
            sizes="(max-width: 820px) 100vw, 33vw"
            format="webp"
            loading="lazy"
          />
          <div class="creation-visual-badge">{locale === "zh" ? "实时预览" : "Live preview"}</div>
          <div class="creation-swatch-row" aria-hidden="true">
            <i style="--swatch: #e4b6ad"></i><i style="--swatch: #f6e9d9"></i><i style="--swatch: #78968d"></i><i style="--swatch: #965c67"></i>
          </div>
        </div>
        <div class="creation-path-copy">
          <div class="creation-path-meta"><span>02</span><Wand2 size={18} stroke-width={1.6} aria-hidden="true" /></div>
          <h3>{locale === "zh" ? "自定义你的主题" : "Build your own theme"}</h3>
          <p>{locale === "zh" ? "上传主图，选择布局，调节配色、透明度和焦点，在首页与对话页实时预览。" : "Upload artwork, choose a layout, and tune colors, transparency, and focus with live home and conversation previews."}</p>
          <button class="creation-path-action" type="button" data-deep-link="codexthemes://create/custom">
            {locale === "zh" ? "打开自定义主题" : "Open theme builder"}<ArrowRight size={16} aria-hidden="true" />
          </button>
        </div>
      </article>

      <article class="creation-path-card creation-path-card--ai">
        <div class="creation-path-visual">
          <Image
            src={aiStudioClient}
            alt={locale === "zh" ? "Codex Themes 客户端 AI 主题工作台" : "Codex Themes desktop AI theme studio"}
            widths={[480, 720, 960]}
            sizes="(max-width: 820px) 100vw, 33vw"
            format="webp"
            loading="lazy"
          />
          <div class="creation-visual-badge">{locale === "zh" ? "本地生成" : "Local generation"}</div>
          <div class="creation-cli-state">
            <span><i></i>{locale === "zh" ? "本地 Codex CLI 已连接" : "Local Codex CLI connected"}</span>
            <code>codex · theme.generate()</code>
          </div>
        </div>
        <div class="creation-path-copy">
          <div class="creation-path-meta"><span>03</span><Sparkles size={18} stroke-width={1.6} aria-hidden="true" /></div>
          <h3>{locale === "zh" ? "用本地 Codex 生成" : "Generate with local Codex"}</h3>
          <p>{locale === "zh" ? "输入一句描述或添加参考图，由本机 Codex CLI 生成主题图片、布局和配色方案。" : "Describe an idea or attach a reference image, then let your local Codex CLI generate artwork, layout, and palette."}</p>
          <button class="creation-path-action" type="button" data-deep-link="codexthemes://create/ai">
            {locale === "zh" ? "连接本地 Codex 生成" : "Create with local Codex"}<ArrowRight size={16} aria-hidden="true" />
          </button>
        </div>
      </article>
    </div>
  </section>

  <section class="theme-showcase section-shell">
    <div class="section-heading-row">
      <div>
        <div class="section-kicker">03 / {locale === "zh" ? "官方主题" : "Official themes"}</div>
        <h2>{locale === "zh" ? "找到今天想进入的工作空间" : "Find the workspace you want today"}</h2>
      </div>
      <a class="button button-text" href={href(locale, "/themes")}>{t.allThemes}</a>
    </div>
    <div class="theme-grid theme-grid--curated">
      {featured.map((theme) => <ThemeCard theme={theme} locale={locale} />)}
    </div>
  </section>

  <section class="steps-section section-shell" id="how-it-works">
    <div class="section-kicker">04 / {t.navHow}</div>
    <h2>{locale === "zh" ? "从网页到 Codex，只需要三步" : "From the web to Codex in three steps"}</h2>
    <div class="steps-grid">
      <article>
        <div class="step-number">1</div>
        <h3>{locale === "zh" ? "更新并安装应用" : "Update and install"}</h3>
        <p>{locale === "zh" ? "先把官方 Codex 升级到最新版，再安装最新版 Codex Themes。" : "Update the official Codex app first, then install the latest Codex Themes."}</p>
      </article>
      <article>
        <div class="step-number">2</div>
        <h3>{locale === "zh" ? "在网页选主题" : "Choose on the web"}</h3>
        <p>{locale === "zh" ? "打开主题详情，点击“使用该主题”。" : "Open any theme detail page and choose “Use this theme.”"}</p>
      </article>
      <article>
        <div class="step-number">3</div>
        <h3>{locale === "zh" ? "在应用中确认" : "Confirm in the app"}</h3>
        <p>{locale === "zh" ? "应用会定位主题，在真正换肤前再向你确认。" : "The app finds the theme and asks once more before applying it."}</p>
      </article>
    </div>
  </section>

  <section class="download-banner section-shell">
    <div>
      <div class="eyebrow">{locale === "zh" ? "你的 CODEX，你的工作台" : "YOUR CODEX, YOUR WORKSPACE"}</div>
      <h2>{locale === "zh" ? "先从蓝窗信使开始。" : "Start with Blue Window."}</h2>
      <p>{locale === "zh" ? `下载后即可使用 ${themes.length} 款精选内置主题，也可以创建自己的主题。` : `Get ${themes.length} curated built-in themes, then create a workspace that is entirely yours.`}</p>
    </div>
    <a class="button button-blue" href={DOWNLOAD_URL}>{t.download}</a>
  </section>

  <section class="faq-section section-shell" id="faq">
    <div class="section-kicker">05 / {t.navFaq}</div>
    <div class="faq-layout">
      <h2>{locale === "zh" ? "下载前，你可能想知道" : "A few things before you download"}</h2>
      <div class="faq-list">
        <details open>
          <summary>{locale === "zh" ? "它会修改 Codex 安装包吗？" : "Does it modify the Codex app?"}</summary>
          <p>{locale === "zh" ? "不会。应用通过本机调试连接注入纯视觉层，不修改 app.asar 或代码签名。" : "No. It uses a local debugging connection for a visual layer and never patches app.asar or its signature."}</p>
        </details>
        <details>
          <summary>{locale === "zh" ? "为什么第一次打开需要手动允许？" : "Why do I need to allow the first launch manually?"}</summary>
          <p>
            {locale === "zh"
              ? "当前 Beta 尚未完成 Apple 签名与公证。可先在“系统设置 → 隐私与安全性”中选择“仍要打开”；若提示应用已损坏，请前往下载页按说明移除 Codex Themes 的 quarantine 隔离属性后重新打开。"
              : "The current Beta is not yet Apple-signed or notarized. Choose Open Anyway in System Settings → Privacy & Security. If macOS reports the app as damaged, follow the download-page steps to remove the quarantine attribute from Codex Themes and reopen it."}
          </p>
        </details>
        <details>
          <summary>{locale === "zh" ? "网页能直接判断我有没有安装吗？" : "Can the website detect whether the app is installed?"}</summary>
          <p>{locale === "zh" ? "浏览器不会公开准确安装状态。网站会尝试唤起应用，失败时再显示下载引导。" : "Browsers do not expose a reliable install status. The site tries the app link first, then shows download help if needed."}</p>
        </details>
        <details>
          <summary>{locale === "zh" ? "可以恢复官方外观吗？" : "Can I restore the official appearance?"}</summary>
          <p>{locale === "zh" ? "可以。应用内提供一键还原，退出守护后 Codex 下次刷新也会恢复官方外观。" : "Yes. Use the one-click restore action; Codex also returns to its official look after the local guard stops and Codex refreshes."}</p>
        </details>
      </div>
    </div>
  </section>

  <script>
    const carouselWindow = window as Window & { __codexThemesHomeCarouselCleanup?: () => void };
    carouselWindow.__codexThemesHomeCarouselCleanup?.();
    const carouselCleanups: Array<() => void> = [];

    document.querySelectorAll<HTMLElement>("[data-home-carousel]").forEach((carousel) => {
      carousel.dataset.carouselReady = "true";
      const controller = new AbortController();
      const { signal } = controller;

      const cards = Array.from(carousel.querySelectorAll<HTMLButtonElement>("[data-carousel-card]"));
      const thumbs = Array.from(carousel.querySelectorAll<HTMLButtonElement>("[data-carousel-thumb]"));
      const backdrops = Array.from(carousel.querySelectorAll<HTMLElement>("[data-backdrop-index]"));
      const stage = carousel.querySelector<HTMLElement>(".home-theme-stage");
      const name = carousel.querySelector<HTMLElement>("[data-carousel-name]");
      const count = carousel.querySelector<HTMLElement>("[data-carousel-count]");
      const progress = carousel.querySelector<HTMLElement>("[data-carousel-progress]");
      let selected = 0;
      let dragStart: number | null = null;
      let autoplay: number | null = null;

      const select = (next: number) => {
        selected = (next + cards.length) % cards.length;
        cards.forEach((card, index) => {
          const depth = (index - selected + cards.length) % cards.length;
          const visible = depth < 3;
          card.dataset.depth = visible ? String(depth) : "hidden";
          card.setAttribute("aria-pressed", String(index === selected));
          card.setAttribute("aria-hidden", String(!visible));
          card.tabIndex = visible ? 0 : -1;
        });
        thumbs.forEach((thumb, index) => {
          thumb.setAttribute("aria-checked", String(index === selected));
        });
        backdrops.forEach((backdrop, index) => {
          backdrop.dataset.active = String(index === selected);
        });
        if (name) name.textContent = thumbs[selected]?.dataset.themeName ?? "";
        if (count) count.textContent = `${String(selected + 1).padStart(2, "0")} / ${String(cards.length).padStart(2, "0")}`;
        if (progress) progress.style.transform = `scaleX(${(selected + 1) / cards.length})`;
        const activeThumb = thumbs[selected];
        const thumbnailRail = activeThumb?.parentElement;
        if (activeThumb && thumbnailRail) {
          thumbnailRail.scrollTo({
            left: activeThumb.offsetLeft - (thumbnailRail.clientWidth - activeThumb.clientWidth) / 2,
            behavior: window.matchMedia("(prefers-reduced-motion: reduce)").matches ? "auto" : "smooth",
          });
        }
      };

      const stopAutoplay = () => {
        if (autoplay !== null) window.clearInterval(autoplay);
        autoplay = null;
      };

      const startAutoplay = () => {
        stopAutoplay();
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
        autoplay = window.setInterval(() => select(selected + 1), 5200);
      };

      carousel.querySelector("[data-carousel-prev]")?.addEventListener("click", (event) => {
        event.stopPropagation();
        select(selected - 1);
      }, { signal });
      carousel.querySelector("[data-carousel-next]")?.addEventListener("click", (event) => {
        event.stopPropagation();
        select(selected + 1);
      }, { signal });
      thumbs.forEach((thumb, index) => thumb.addEventListener("click", () => select(index), { signal }));
      cards.forEach((card, index) => card.addEventListener("click", () => select(index), { signal }));

      carousel.addEventListener("keydown", (event) => {
        if (event.key === "ArrowLeft") {
          event.preventDefault();
          select(selected - 1);
        }
        if (event.key === "ArrowRight") {
          event.preventDefault();
          select(selected + 1);
        }
      }, { signal });

      stage?.addEventListener("pointerdown", (event) => {
        if ((event.target as Element).closest("[data-carousel-prev], [data-carousel-next]")) return;
        dragStart = event.clientX;
        stage.setPointerCapture(event.pointerId);
      }, { signal });
      stage?.addEventListener("pointerup", (event) => {
        if (dragStart === null) return;
        const distance = event.clientX - dragStart;
        if (Math.abs(distance) > 54) select(selected + (distance < 0 ? 1 : -1));
        dragStart = null;
      }, { signal });
      stage?.addEventListener("pointercancel", () => {
        dragStart = null;
      }, { signal });

      carousel.addEventListener("pointerenter", stopAutoplay, { signal });
      carousel.addEventListener("pointerleave", startAutoplay, { signal });
      carousel.addEventListener("focusin", stopAutoplay, { signal });
      carousel.addEventListener("focusout", (event) => {
        if (!carousel.contains(event.relatedTarget as Node | null)) startAutoplay();
      }, { signal });
      document.addEventListener("visibilitychange", () => {
        if (document.hidden) stopAutoplay();
        else startAutoplay();
      }, { signal });

      select(0);
      startAutoplay();
      carouselCleanups.push(() => {
        stopAutoplay();
        controller.abort();
      });
    });

    carouselWindow.__codexThemesHomeCarouselCleanup = () => {
      carouselCleanups.splice(0).forEach((cleanup) => cleanup());
    };
  </script>
</BaseLayout>
