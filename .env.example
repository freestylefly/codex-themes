# Supabase (public keys for the Electron app)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Commerce API base URL (Vercel deployment)
VITE_COMMERCE_API_URL=https://your-deployment.vercel.app

# Supabase (server-side only, Vercel Functions)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional legacy HS256 fast path. Leave empty to validate through Supabase Auth.
SUPABASE_JWT_SECRET=

# Alipay (optional, server-side only, Vercel Functions)
ALIPAY_APP_ID=your-app-id
ALIPAY_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
ALIPAY_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
ALIPAY_SELLER_ID=your-seller-id
ALIPAY_GATEWAY=https://openapi-sandbox.dl.alipaydev.com/gateway.do

# Vercel Functions self-reference
COMMERCE_API_URL=https://your-deployment.vercel.app
